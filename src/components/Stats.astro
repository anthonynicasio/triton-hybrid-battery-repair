---
const stats = [
  {
    value: '4.9★',
    label: 'Google Rating',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.9L22 10l-5.5 4.8L18 22l-6-3.7L6 22l1.5-7.2L2 10l7.1-1.1L12 2z"/></svg>`,
  },
  {
    value: '156+',
    label: '5-Star Reviews',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
  },
  {
    value: '$1.5K+',
    label: 'Avg. Savings vs Dealer',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  },
  {
    value: 'Prius',
    label: 'Gen 2, 3, 4 & Prime',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2"/><circle cx="6.5" cy="16.5" r="2.5"/><circle cx="16.5" cy="16.5" r="2.5"/></svg>`,
  },
];
---

<section class="py-16 md:py-20 bg-white border-y border-slate-100">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-6">
      {stats.map((s, i) => (
        <div
          class="flex flex-col items-center text-center reveal"
          style={`transition-delay: ${i * 80}ms;`}
        >
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-brand-50 text-brand-600">
            <Fragment set:html={s.icon} />
          </div>
          <div class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900">
            {s.value}
          </div>
          <div class="mt-1.5 text-sm font-medium text-slate-500">
            {s.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
