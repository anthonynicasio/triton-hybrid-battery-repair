---
import { homepageServicePages } from '../data/services';

const serviceImages = ['/images/mechanic-lamp.png', '/images/mechanic-oil.png', '/images/mechanic-wrench.png'];
---

<section id="services" class="py-20 md:py-28 bg-slate-50">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <!-- Header -->
    <div class="max-w-2xl reveal">
      <span class="text-xs font-bold tracking-[0.2em] uppercase text-brand-600">Our Services</span>
      <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
        The most requested hybrid services in one place.
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Start with the repairs drivers in Northern Virginia ask for most, then get a
        clear quote before any work begins.
      </p>
    </div>

    <!-- Grid -->
    <div class="mt-12 md:mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-7">
      {homepageServicePages.map((s, i) => (
        <article
          class="group bg-white rounded-2xl overflow-hidden shadow-lg ring-1 ring-slate-900/5 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 reveal flex flex-col"
          style={`transition-delay: ${i * 90}ms;`}
        >
          <div class="relative aspect-[4/3] overflow-hidden bg-slate-100">
            <img
              src={serviceImages[i % serviceImages.length]}
              alt={s.name}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 to-transparent"></div>
          </div>
          <div class="p-6 flex-1 flex flex-col">
            <h3 class="text-xl font-bold text-slate-900 group-hover:text-brand-600 transition-colors duration-300">{s.name}</h3>
            <p class="mt-2 text-sm text-slate-500 leading-relaxed">{s.shortDescription}</p>

            <ul class="mt-4 space-y-1.5">
              {s.includes.slice(0, 3).map((b) => (
                <li class="flex items-center gap-2 text-sm text-slate-700">
                  <svg class="text-brand-600 shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  {b}
                </li>
              ))}
            </ul>

            <a href={`/services/${s.slug}/`} class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:gap-2.5 transition-all duration-300">
              View service page
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Bottom callout -->
    <div class="mt-14 rounded-2xl bg-white ring-1 ring-slate-900/5 shadow-lg p-6 md:p-8 flex flex-col md:flex-row items-center gap-6 md:gap-8 reveal">
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-brand-50 text-brand-600 shrink-0">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg>
      </div>
      <div class="flex-1 text-center md:text-left">
        <h3 class="text-xl font-bold text-slate-900">Need help now? Start with a free quote.</h3>
        <p class="mt-1 text-slate-500">Tell us what your car is doing and we will point you to the right next step.</p>
      </div>
      <div class="flex flex-wrap justify-center md:justify-end gap-3 shrink-0">
        <a href="/#hero-form" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-semibold shadow-brand hover:-translate-y-0.5 transition-all duration-300">
          Get Free Quote
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="/services/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white ring-1 ring-slate-200 hover:ring-slate-300 text-slate-900 font-semibold hover:-translate-y-0.5 transition-all duration-300">
          View All Services
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
