---
const steps = [
  {
    title: 'Call or request a quote',
    desc: 'Tell us what\'s going on — warning lights, reduced MPG, or a dealership quote you want reviewed.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z"/></svg>`,
  },
  {
    title: 'Honest hybrid diagnosis',
    desc: 'Module-level testing finds the real issue — not just the easy upsell. Full written report included.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>`,
  },
  {
    title: 'Fair-priced repair',
    desc: 'Transparent quote. Premium warranty. Back on the road — often for thousands less than the dealer.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
];
---

<section id="how" class="py-20 md:py-28 bg-slate-50">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="text-center max-w-2xl mx-auto reveal">
      <span class="text-xs font-bold tracking-[0.2em] uppercase text-brand-600">How It Works</span>
      <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
        Three simple steps.
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        From first call to healthy hybrid — no runaround, no surprises.
      </p>
    </div>

    <!-- Steps -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 relative">
      <!-- Dashed connector line (desktop only) -->
      <div aria-hidden="true" class="hidden md:block absolute top-10 left-[16.66%] right-[16.66%] step-dashed -z-0"></div>

      {steps.map((s, i) => (
        <div
          class="relative flex flex-col items-center text-center reveal"
          style={`transition-delay: ${i * 120}ms;`}
        >
          <!-- Icon circle -->
          <div class="relative inline-flex items-center justify-center w-20 h-20 rounded-full bg-white shadow-lg ring-1 ring-slate-900/5 text-brand-600 z-10">
            <Fragment set:html={s.icon} />
            <span class="absolute -top-2 -right-2 inline-flex items-center justify-center w-7 h-7 rounded-full bg-brand-600 text-white text-xs font-bold shadow-md">
              {i + 1}
            </span>
          </div>

          <h3 class="mt-6 text-xl font-bold text-slate-900">{s.title}</h3>
          <p class="mt-2 max-w-xs text-slate-500 leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-14 text-center reveal">
      <a
        href="#hero-form"
        class="inline-flex items-center gap-2 px-7 py-4 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-semibold shadow-brand hover:-translate-y-0.5 transition-all duration-300"
      >
        Start With a Free Quote
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
