          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="/#hero-form" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white ring-1 ring-slate-200 hover:ring-slate-300 text-slate-900 font-semibold hover:-translate-y-0.5 transition-all duration-300">
          Get Free Quote
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
