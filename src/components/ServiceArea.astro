    <div class="rounded-2xl bg-white ring-1 ring-slate-900/5 shadow-lg p-6 md:p-8 reveal">
      <span class="text-xs font-bold tracking-[0.2em] uppercase text-brand-600">Service Area</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
