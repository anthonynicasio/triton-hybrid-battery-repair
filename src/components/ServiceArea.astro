      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/service-areas/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-semibold shadow-brand hover:-translate-y-0.5 transition-all duration-300">
