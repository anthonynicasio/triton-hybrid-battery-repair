---
const year = new Date().getFullYear();
---

<!-- Final CTA band -->
<section class="py-16 md:py-20 leaf-pattern text-white">
  <div class="mx-auto max-w-5xl px-5 md:px-8 text-center reveal">
    <span class="text-xs font-bold tracking-[0.2em] uppercase text-brand-300">Ready to save thousands?</span>
    <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight">
      Honest Hybrid Experts. <br class="hidden sm:inline" />
      <span class="text-brand-400">Dealership Quality — Without Dealership Prices.</span>
    </h2>
    <p class="mt-5 text-slate-200 text-lg max-w-2xl mx-auto">
      Talk to a real hybrid specialist today. Free quote, no pressure, no upsell.
    </p>
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a
        href="tel:+17032619442"
        class="inline-flex items-center gap-2 px-7 py-4 rounded-xl bg-brand-500 hover:bg-brand-600 text-white font-semibold shadow-brand hover:-translate-y-0.5 transition-all duration-300"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z"/></svg>
        Call (703) 261-9442
      </a>
      <a
        href="#hero-form"
        class="inline-flex items-center gap-2 px-7 py-4 rounded-xl bg-white/10 hover:bg-white/20 text-white font-semibold ring-1 ring-white/20 hover:-translate-y-0.5 transition-all duration-300"
      >
        Request Free Quote
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<footer class="bg-[#111111] text-slate-300">
  <div class="mx-auto max-w-7xl px-5 md:px-8 py-14 md:py-16">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 md:gap-8">
      <!-- Logo + bio -->
      <div class="col-span-2 lg:col-span-1">
        <a href="#top" class="flex items-center gap-3">
          <img src="/images/logo.png" alt="Triton Hybrid Battery Repair" class="h-14 w-14 object-contain" width="56" height="56" />
          <span class="flex flex-col leading-tight">
            <span class="font-extrabold text-lg text-white">Triton Hybrid</span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-brand-400">Battery Repair</span>
          </span>
        </a>
        <p class="mt-5 text-sm text-slate-400 leading-relaxed max-w-sm">
          Northern Virginia's trusted Prius &amp; hybrid specialist, based in Lorton, VA.
          Honest diagnostics, fair pricing, premium warranty — saving drivers thousands
          versus the dealership.
        </p>
        <div class="mt-5 flex items-center gap-3">
          <a aria-label="Facebook" href="#" class="w-9 h-9 inline-flex items-center justify-center rounded-lg bg-white/5 hover:bg-brand-600 text-slate-300 hover:text-white transition-all duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.5 9.87V15H8v-3h2.5V9.8c0-2.47 1.47-3.8 3.7-3.8 1.07 0 2.2.2 2.2.2v2.42h-1.24c-1.22 0-1.6.76-1.6 1.53V12H16l-.44 3H13.5v6.87A10 10 0 0 0 22 12z"/></svg>
          </a>
          <a aria-label="Instagram" href="#" class="w-9 h-9 inline-flex items-center justify-center rounded-lg bg-white/5 hover:bg-brand-600 text-slate-300 hover:text-white transition-all duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a aria-label="Google" href="#" class="w-9 h-9 inline-flex items-center justify-center rounded-lg bg-white/5 hover:bg-brand-600 text-slate-300 hover:text-white transition-all duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.35 11.1H12v2.95h5.35c-.23 1.5-1.74 4.4-5.35 4.4-3.22 0-5.85-2.66-5.85-5.95s2.63-5.95 5.85-5.95c1.83 0 3.06.77 3.76 1.43l2.57-2.48C16.92 3.88 14.73 3 12 3 6.98 3 3 6.98 3 12s3.98 9 9 9c5.2 0 8.64-3.65 8.64-8.8 0-.6-.07-1.06-.17-1.55z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-bold text-sm tracking-wide uppercase">Quick Links</h4>
        <ul class="mt-5 space-y-3 text-sm">
          <li><a href="#about" class="text-slate-400 hover:text-brand-400 transition-colors">About</a></li>
          <li><a href="#services" class="text-slate-400 hover:text-brand-400 transition-colors">Services</a></li>
          <li><a href="#reviews" class="text-slate-400 hover:text-brand-400 transition-colors">Reviews</a></li>
          <li><a href="#how" class="text-slate-400 hover:text-brand-400 transition-colors">How It Works</a></li>
          <li><a href="#hero-form" class="text-slate-400 hover:text-brand-400 transition-colors">Get a Quote</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white font-bold text-sm tracking-wide uppercase">Services</h4>
        <ul class="mt-5 space-y-3 text-sm">
          <li><a href="#services" class="text-slate-400 hover:text-brand-400 transition-colors">Hybrid Battery Diagnostics</a></li>
          <li><a href="#services" class="text-slate-400 hover:text-brand-400 transition-colors">Battery Repair &amp; Reconditioning</a></li>
          <li><a href="#services" class="text-slate-400 hover:text-brand-400 transition-colors">Battery Replacement</a></li>
          <li><a href="#services" class="text-slate-400 hover:text-brand-400 transition-colors">Prius Specialty Repair</a></li>
          <li><a href="#services" class="text-slate-400 hover:text-brand-400 transition-colors">Hybrid Cooling System</a></li>
        </ul>
      </div>

      <!-- Visit Us -->
      <div>
        <h4 class="text-white font-bold text-sm tracking-wide uppercase">Visit the Shop</h4>
        <ul class="mt-5 space-y-3 text-sm">
          <li class="flex items-start gap-2.5 text-slate-400">
            <svg class="shrink-0 mt-0.5 text-brand-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <a href="https://www.google.com/maps/search/?api=1&query=8419+Terminal+Rd,+Lorton,+VA+22079" target="_blank" rel="noopener" class="hover:text-brand-400 transition-colors">
              8419 Terminal Rd<br />Lorton, VA 22079
            </a>
          </li>
          <li class="flex items-start gap-2.5 text-slate-400">
            <svg class="shrink-0 mt-0.5 text-brand-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z"/></svg>
            <a href="tel:+17032619442" class="hover:text-brand-400 transition-colors">(703) 261-9442</a>
          </li>
          <li class="flex items-start gap-2.5 text-slate-400">
            <svg class="shrink-0 mt-0.5 text-brand-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:tritonhybridbattery@gmail.com" class="hover:text-brand-400 transition-colors break-all">tritonhybridbattery@gmail.com</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Hours strip -->
    <div class="mt-12 rounded-2xl bg-white/5 ring-1 ring-white/10 p-6 md:p-7">
      <div class="flex items-center gap-2.5 mb-4">
        <svg class="text-brand-400" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <h4 class="text-white font-bold text-sm tracking-wide uppercase">Shop Hours</h4>
      </div>
      <dl class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-x-6 gap-y-3 text-sm">
        <div><dt class="text-slate-500 text-xs font-semibold uppercase tracking-wider">Mon</dt><dd class="mt-0.5 text-slate-500">Closed</dd></div>
        <div><dt class="text-slate-500 text-xs font-semibold uppercase tracking-wider">Tue</dt><dd class="mt-0.5 text-slate-200">9:30a – 5p</dd></div>
        <div><dt class="text-slate-500 text-xs font-semibold uppercase tracking-wider">Wed</dt><dd class="mt-0.5 text-slate-200">9:30a – 5p</dd></div>
        <div><dt class="text-slate-500 text-xs font-semibold uppercase tracking-wider">Thu</dt><dd class="mt-0.5 text-slate-200">9:30a – 5p</dd></div>
        <div><dt class="text-slate-500 text-xs font-semibold uppercase tracking-wider">Fri</dt><dd class="mt-0.5 text-slate-200">9:30a – 6p</dd></div>
        <div><dt class="text-brand-300 text-xs font-semibold uppercase tracking-wider">Sat</dt><dd class="mt-0.5 text-brand-300 font-semibold">9a – 7p</dd></div>
        <div><dt class="text-slate-500 text-xs font-semibold uppercase tracking-wider">Sun</dt><dd class="mt-0.5 text-slate-500">Closed</dd></div>
      </dl>
    </div>

    <div class="mt-14 pt-6 border-t border-white/10 flex items-center justify-between flex-wrap gap-3 text-xs text-slate-500">
      <span>© {year} Triton Hybrid Battery Repair. All rights reserved.</span>
      <div class="flex gap-6">
        <a href="#" class="hover:text-brand-400 transition-colors">Privacy</a>
        <a href="#" class="hover:text-brand-400 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
