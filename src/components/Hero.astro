---
const features = [
  'Save thousands vs dealership',
  'Honest, transparent diagnostics',
  'Premium warranty on every repair',
];

const makes = [
  'Toyota Prius',
  'Toyota Prius Prime',
  'Toyota Camry Hybrid',
  'Toyota Highlander Hybrid',
  'Lexus RX / ES Hybrid',
  'Honda Civic Hybrid',
  'Honda Insight',
  'Honda Accord Hybrid',
  'Ford Fusion Hybrid',
  'Hyundai Ioniq',
  'Kia Niro Hybrid',
  'Other / Not listed',
];
---

<section id="top" class="relative overflow-hidden bg-white">
  <!-- Subtle background accents -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-32 -right-32 w-[500px] h-[500px] rounded-full bg-brand-50 blur-3xl opacity-80"></div>
    <div class="absolute bottom-0 -left-32 w-[400px] h-[400px] rounded-full bg-slate-100 blur-3xl opacity-70"></div>
  </div>

  <div class="mx-auto max-w-7xl px-5 md:px-8 pt-12 md:pt-20 pb-20 md:pb-28">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-10 items-center">
      <!-- LEFT: copy -->
      <div class="lg:col-span-7 reveal">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-50 text-brand-700 text-xs font-semibold tracking-wide uppercase ring-1 ring-brand-200">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-brand-600"></span>
          Northern Virginia's Prius &amp; Hybrid Specialist
        </span>

        <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold tracking-tight text-slate-900 leading-[1.05]">
          Honest Hybrid Experts.<br class="hidden sm:inline" />
          Dealership Quality <span class="accent-underline text-brand-600">Without Dealership Prices.</span>
        </h1>

        <p class="mt-6 max-w-xl text-lg text-slate-600 leading-relaxed">
          Our customers call Sal the <em>Prius Whisperer</em>. Specialist hybrid battery
          diagnostics, repair, reconditioning, and replacement — saving customers
          <strong class="text-slate-900">thousands</strong> versus dealership quotes,
          with a premium warranty on every repair.
        </p>

        <!-- Checkmarks -->
        <ul class="mt-8 flex flex-wrap gap-x-8 gap-y-3">
          {features.map((f) => (
            <li class="flex items-center gap-2.5 text-slate-700 font-medium">
              <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-brand-600 text-white shrink-0">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              {f}
            </li>
          ))}
        </ul>

        <!-- CTAs -->
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="tel:+17032619442"
            class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-semibold shadow-brand hover:-translate-y-0.5 transition-all duration-300"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z"/></svg>
            Call (703) 261-9442
          </a>
          <a
            href="#hero-form"
            class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl bg-white ring-1 ring-slate-200 hover:ring-slate-300 text-slate-900 font-semibold shadow-sm hover:-translate-y-0.5 transition-all duration-300"
          >
            Request a Free Quote
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Social proof row -->
        <div class="mt-8 flex items-center gap-5 flex-wrap">
          <div class="flex items-center gap-2">
            <div class="flex -space-x-2">
              <div class="w-8 h-8 rounded-full bg-brand-500 ring-2 ring-white"></div>
              <div class="w-8 h-8 rounded-full bg-brand-600 ring-2 ring-white"></div>
              <div class="w-8 h-8 rounded-full bg-teal-800 ring-2 ring-white"></div>
              <div class="w-8 h-8 rounded-full bg-brand-700 ring-2 ring-white"></div>
            </div>
          </div>
          <div class="text-sm">
            <div class="flex items-center gap-1 text-brand-600">
              {Array.from({ length: 5 }).map(() => (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.9L22 10l-5.5 4.8L18 22l-6-3.7L6 22l1.5-7.2L2 10l7.1-1.1L12 2z"/></svg>
              ))}
              <span class="ml-1.5 font-bold text-slate-900">4.9</span>
            </div>
            <div class="text-slate-500">Trusted by <strong class="text-slate-900">150+</strong> 5-star customers on Google</div>
          </div>
        </div>

        <!-- Hero image -->
        <div class="mt-10 relative rounded-2xl overflow-hidden shadow-xl ring-1 ring-slate-900/5 aspect-[16/10]">
          <img
            src="/images/mechanic-lamp.png"
            alt="Triton Hybrid technician diagnosing a hybrid battery system"
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/30 to-transparent"></div>
          <div class="absolute bottom-4 left-4 right-4 flex items-center justify-between text-white">
            <div class="bg-black/40 backdrop-blur-sm rounded-lg px-3 py-1.5 text-xs font-medium">
              Specialist hybrid diagnostics — right here in NoVA
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: floating booking form -->
      <div class="lg:col-span-5 reveal" style="transition-delay: 120ms;">
        <form
          id="hero-form"
          class="relative bg-white rounded-2xl shadow-2xl ring-1 ring-slate-900/5 p-6 sm:p-8 lg:p-9"
          onsubmit="event.preventDefault(); this.querySelector('[data-success]').classList.remove('hidden'); this.reset();"
        >
          <div class="absolute -top-3 left-6 inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-brand-600 text-white text-[11px] font-semibold tracking-wider uppercase shadow-md">
            Free · No-Obligation
          </div>

          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">Get Your Honest Quote</h2>
          <p class="mt-2 text-slate-500">
            Tell us about your hybrid — we'll respond within one business hour.
          </p>

          <div class="mt-6 space-y-4">
            <div>
              <label for="name" class="block text-xs font-semibold uppercase tracking-wide text-slate-500 mb-1.5">Full Name</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Jane Doe"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent focus:bg-white transition-all duration-300"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="email" class="block text-xs font-semibold uppercase tracking-wide text-slate-500 mb-1.5">Email</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  placeholder="jane@example.com"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent focus:bg-white transition-all duration-300"
                />
              </div>
              <div>
                <label for="phone" class="block text-xs font-semibold uppercase tracking-wide text-slate-500 mb-1.5">Phone</label>
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  required
                  placeholder="(703) 555-0100"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent focus:bg-white transition-all duration-300"
                />
              </div>
            </div>

            <div>
              <label for="vehicle" class="block text-xs font-semibold uppercase tracking-wide text-slate-500 mb-1.5">Vehicle Make / Model</label>
              <select
                id="vehicle"
                name="vehicle"
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent focus:bg-white transition-all duration-300 appearance-none bg-[url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%2364748b%22 stroke-width=%222.5%22><polyline points=%226 9 12 15 18 9%22/></svg>')] bg-no-repeat bg-[right_1rem_center] pr-10"
              >
                <option value="" disabled selected>Select your hybrid...</option>
                {makes.map((m) => <option value={m}>{m}</option>)}
              </select>
            </div>

            <div>
              <label for="issue" class="block text-xs font-semibold uppercase tracking-wide text-slate-500 mb-1.5">What's going on?</label>
              <textarea
                id="issue"
                name="issue"
                rows="3"
                placeholder="Warning lights, reduced MPG, battery warning, dealership quote, etc."
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-600 focus:border-transparent focus:bg-white transition-all duration-300 resize-none"
              ></textarea>
            </div>
          </div>

          <button
            type="submit"
            class="mt-6 w-full inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-semibold shadow-brand hover:-translate-y-0.5 transition-all duration-300"
          >
            Request Free Quote
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </button>

          <p class="mt-4 text-center text-xs text-slate-400">
            Prefer to talk? Call <a href="tel:+17032619442" class="font-semibold text-slate-700 hover:text-brand-600">(703) 261-9442</a>
          </p>

          <div data-success class="hidden mt-4 rounded-xl bg-brand-50 border border-brand-200 p-3 text-sm text-brand-800">
            Thanks! We'll reach out within one business hour with your honest quote.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
