---
import Base from '../layouts/Base.astro';

const serviceAreas = [
  {
    city: 'Lorton, VA',
    description:
      'Our shop is based in Lorton, making drop-offs and quick turnaround easy for local drivers who need dependable hybrid and battery care.',
  },
  {
    city: 'Alexandria, VA',
    description:
      'Alexandria drivers visit us for honest diagnostics and clear repair plans that help avoid dealership-level pricing without cutting quality.',
  },
  {
    city: 'Springfield, VA',
    description:
      'From warning lights to battery concerns, Springfield customers choose our team for practical recommendations and straightforward service.',
  },
  {
    city: 'Arlington, VA',
    description:
      'Arlington commuters trust us for reliable hybrid support that keeps daily driving smooth, efficient, and less stressful.',
  },
  {
    city: 'Washington, DC',
    description:
      'Many Washington, DC owners come to our Lorton location for Prius-focused diagnostics, battery repair options, and transparent communication.',
  },
];

const pageTitle = 'Hybrid Repair Service Areas | Lorton, Alexandria, Springfield, Arlington & Washington DC';
const pageDescription =
  'See the cities Triton Hybrid Battery Repair serves across Northern Virginia and the DMV, including Lorton, Alexandria, Springfield, Arlington, and Washington DC.';
---

<Base title={pageTitle} description={pageDescription} canonicalPath="/service-areas/">
  <section class="bg-slate-50 py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-5 md:px-8">
      <span class="text-xs font-bold tracking-[0.2em] uppercase text-brand-600">Service Areas</span>
      <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900">
        Proudly serving Northern Virginia and the DMV
      </h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-600">
        We regularly help drivers from Lorton, Alexandria, Springfield, Arlington, and Washington, DC.
        If you are nearby and dealing with hybrid or battery issues, we are ready to help with clear answers and honest pricing.
      </p>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
        {serviceAreas.map((area) => (
          <article class="bg-white rounded-2xl p-6 ring-1 ring-slate-900/5 shadow-sm">
            <h2 class="text-2xl font-bold text-slate-900">{area.city}</h2>
            <p class="mt-3 text-slate-600 leading-relaxed">{area.description}</p>
            <a href="/#hero-form" class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-600 hover:gap-3 transition-all">
              Get Free Quote
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </article>
        ))}
      </div>

      <div class="mt-12 rounded-2xl bg-white ring-1 ring-slate-900/5 shadow-lg p-6 md:p-8 flex flex-col md:flex-row items-center gap-6 md:gap-8">
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl font-bold text-slate-900">Need to book your visit now?</h2>
          <p class="mt-2 text-slate-500">
            Use our scheduling page to choose your next step, then send your request in under a minute.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 justify-center md:justify-end">
          <a href="/schedule/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-semibold shadow-brand hover:-translate-y-0.5 transition-all duration-300">
            Go to Schedule Page
          </a>
          <a href="/services/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white ring-1 ring-slate-200 hover:ring-slate-300 text-slate-900 font-semibold hover:-translate-y-0.5 transition-all duration-300">
            Explore Services
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
