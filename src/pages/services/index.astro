---
import Base from '../../layouts/Base.astro';
import { servicePages } from '../../data/services';

const pageTitle = 'Auto Repair Services in Lorton, VA | Triton Hybrid Battery Repair';
const pageDescription =
  'Explore dedicated service pages for brake repair, oil changes, diagnostics, electrical work, and more from Triton Hybrid Battery Repair in Lorton, Virginia.';
---

<Base title={pageTitle} description={pageDescription} canonicalPath="/services/">
  <section class="bg-slate-50 py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-5 md:px-8">
      <span class="text-xs font-bold tracking-[0.2em] uppercase text-brand-600">Service Pages</span>
      <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900">
        Auto repair services in Lorton, Virginia
      </h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-600">
        Use these dedicated service pages to quickly find the repair or maintenance support you need.
        Every page includes symptoms, coverage details, and direct next steps to schedule service.
      </p>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {servicePages.map((service) => (
          <article class="bg-white rounded-2xl p-6 ring-1 ring-slate-900/5 shadow-sm hover:shadow-md transition-shadow">
            <h2 class="text-xl font-bold text-slate-900">{service.name}</h2>
            <p class="mt-2 text-sm text-slate-500">{service.shortDescription}</p>
            <a
              href={`/services/${service.slug}/`}
              class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-600 hover:gap-3 transition-all"
            >
              View service details
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>
