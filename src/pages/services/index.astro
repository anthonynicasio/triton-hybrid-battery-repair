---
import Base from '../../layouts/Base.astro';
import { servicePages } from '../../data/services';
import {
  buildBreadcrumbSchema,
  buildServiceSchema,
  buildWebPageSchema,
} from '../../data/seo';

const pageTitle = 'Hybrid Battery Repair & Auto Services in Lorton, VA | Triton Hybrid';
const pageDescription =
  'Explore Prius battery replacement, hybrid battery repair, diagnostic service, and full auto care from Triton Hybrid in Lorton serving Northern Virginia and the DMV.';

const canonicalPath = '/services/';
const structuredData = [
  buildWebPageSchema({
    path: canonicalPath,
    title: pageTitle,
    description: pageDescription,
    pageType: 'CollectionPage',
  }),
  buildBreadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Services', path: canonicalPath },
  ]),
  ...servicePages.map((service) =>
    buildServiceSchema({
      name: service.name,
      description: service.shortDescription,
      path: `/services/${service.slug}/`,
    })
  ),
];
---

<Base
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalPath}
  structuredData={structuredData}
>
  <section class="bg-slate-50 py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-5 md:px-8">
      <span class="text-xs font-bold tracking-[0.2em] uppercase text-brand-600">Our Services</span>
      <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900">
        Hybrid and auto repair services in Lorton
      </h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-600">
        Start with your most urgent issue, then request a quote when you are ready.
        Each page explains what we check, what we repair, and what to do next.
      </p>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {servicePages.map((service) => (
          <article class="bg-white rounded-2xl p-6 ring-1 ring-slate-900/5 shadow-sm hover:shadow-md transition-shadow">
            <h2 class="text-xl font-bold text-slate-900">{service.name}</h2>
            <p class="mt-2 text-sm text-slate-500">{service.shortDescription}</p>
            <a
              href={`/services/${service.slug}/`}
              class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-600 hover:gap-3 transition-all"
            >
              View service details
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>
